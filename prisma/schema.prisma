generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String    @id @default(cuid())
  name        String
  category    String    // Plain string for now
  categoryId  String?   // Link to dynamic category
  categoryRel Category? @relation(fields: [categoryId], references: [id])
  price       Float
  costPrice   Float     @default(0)
  oldPrice    Float?
  badge       String?
  desc        String?
  stock       Int       @default(0)
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  publishAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  orderItems  OrderItem[]
  comboItems  ComboItem[]
  priceRules  PriceRule[]
  buyGiftOffers GiftOffer[] @relation("BuyProduct")
  getGiftOffers GiftOffer[] @relation("GetProduct")
}

model Order {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  customerName  String
  customerPhone String
  region        String
  address       String
  total         Float
  status        String    @default("قيد المعالجة")
  paymentMethod String    @default("COD")
  createdAt     DateTime  @default(now())
  
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  imageUrl  String?
  createdAt DateTime  @default(now())
  products  Product[]
  giftOffers GiftOffer[] @relation("BuyCategoryGifts")
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String   // e.g., "Marketing", "Shipping", "Hosting"
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model GlobalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model ContactProduct {
  id          String   @id @default(cuid())
  name        String
  price       Float?
  oldPrice    Float?
  imageUrl    String?
  whatsappNum String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// نظام الكومبو - خصم عند شراء عدة منتجات معاً
model Combo {
  id              String      @id @default(cuid())
  name            String
  description     String?
  discountPercent Float
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           ComboItem[]
}

model ComboItem {
  id        String  @id @default(cuid())
  comboId   String
  productId String
  quantity  Int     @default(1)
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

// نظام السعر على الكمية
model PriceRule {
  id        String  @id @default(cuid())
  productId String
  minQty    Int
  price     Float
  label     String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// نظام الهدايا - اشتر منتج واحصل على آخر هدية
model GiftOffer {
  id              String   @id @default(cuid())
  buyProductId    String?
  buyCategoryId   String?
  minPrice        Float?
  
  buyProduct      Product?  @relation("BuyProduct", fields: [buyProductId], references: [id], onDelete: Cascade)
  buyCategory     Category? @relation("BuyCategoryGifts", fields: [buyCategoryId], references: [id], onDelete: Cascade)
  
  getProductId    String
  getProduct      Product   @relation("GetProduct", fields: [getProductId], references: [id], onDelete: Cascade)
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

